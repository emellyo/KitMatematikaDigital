@using System.Globalization
@{
    ViewData["Title"] = "Trigonometri 1";
    string F(double d) => d.ToString("0.##", CultureInfo.InvariantCulture);
    bool IsRed(int deg) => deg == 45 || deg == 135 || deg == 225 || deg == 315;

    int[] degs = { 0, 30, 45, 60, 90, 120, 135, 150, 180, 210, 225, 240, 270, 300, 315, 330, 360 };
    var radNum = new[] { "0", "œÄ", "œÄ", "œÄ", "œÄ", "2œÄ", "3œÄ", "5œÄ", "œÄ", "7œÄ", "5œÄ", "4œÄ", "3œÄ", "5œÄ", "7œÄ", "11œÄ", "2œÄ" };
    var radDen = new[] { "", "6", "4", "3", "2", "3", "4", "6", "", "6", "4", "3", "2", "3", "4", "6", "" };

    var sinv = new[] { "0", "1/2", "‚àö2/2", "‚àö3/2", "1", "‚àö3/2", "‚àö2/2", "1/2", "0", "-1/2", "-‚àö2/2", "-‚àö3/2", "-1", "-‚àö3/2", "-‚àö2/2", "-1/2", "0" };
    var cosv = new[] { "1", "‚àö3/2", "‚àö2/2", "1/2", "0", "-1/2", "-‚àö2/2", "-‚àö3/2", "-1", "-‚àö3/2", "-‚àö2/2", "-1/2", "0", "1/2", "‚àö2/2", "‚àö3/2", "1" };
    var tanv = new[] { "0", "1/‚àö3", "1", "‚àö3", "td", "-‚àö3", "-1", "-1/‚àö3", "0", "1/‚àö3", "1", "‚àö3", "td", "-‚àö3", "-1", "-1/‚àö3", "0" };
    var cscv = new[] { "td", "2", "‚àö2", "2/‚àö3", "1", "2/‚àö3", "‚àö2", "2", "td", "-2", "-‚àö2", "-2/‚àö3", "-1", "-2/‚àö3", "-‚àö2", "-2", "td" };
    var secv = new[] { "1", "2/‚àö3", "‚àö2", "2", "td", "-2", "-‚àö2", "-2/‚àö3", "-1", "-2/‚àö3", "-‚àö2", "-2", "td", "2", "‚àö2", "2/‚àö3", "1" };
    var cotv = new[] { "td", "‚àö3", "1", "1/‚àö3", "0", "-1/‚àö3", "-1", "-‚àö3", "td", "‚àö3", "1", "1/‚àö3", "0", "-1/‚àö3", "-1", "-‚àö3", "td" };

    var rows = new[] {
        new { name = "Sin Œ∏", vals = sinv },
        new { name = "Cos Œ∏", vals = cosv },
        new { name = "Tan Œ∏", vals = tanv },
        new { name = "Csc Œ∏", vals = cscv },
        new { name = "Sec Œ∏", vals = secv },
        new { name = "Cot Œ∏", vals = cotv }
    };

    Func<string, string, string> radHtml = (num, den) =>
        string.IsNullOrEmpty(den)
            ? $"<span class='cf-whole'>{num}</span>"
            : $"<span class='cfrac'><span class='cf-n'>{num}</span><span class='cf-d'>{den}</span></span>";

    // Circle geometry (16 titik; 360¬∞ berimpit dengan 0¬∞)
    double cx = 280, cy = 280, R = 180, RI = 224, RR = 254;
    int[] cdegs = { 0, 30, 45, 60, 90, 120, 135, 150, 180, 210, 225, 240, 270, 300, 315, 330 };
}

<style>
    .kit-container { padding: 28px 32px; max-width: 1180px; }
    .kit-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 8px; color: #2c5f7c; }
    .kit-title-bar { border: none; border-top: 3px solid #e67e22; width: 60px; margin: 0 0 20px 0; }

    /* Tabs */
    .kit-tabs { display: flex; gap: 0; }
    .kit-tab {
        padding: 11px 30px; background: #dce6ec; color: #2c5f7c; border: none; cursor: pointer;
        font-weight: bold; font-size: 1rem; border-radius: 10px 10px 0 0; transition: background .3s, color .3s;
    }
    .kit-tab:hover { background: #c5d5df; }
    .kit-tab.active { background: #2c5f7c; color: #fff; }
    .kit-panel { display: none; background: #fff; border: 2px solid #2c5f7c; border-radius: 0 10px 10px 10px; padding: 26px; }
    .kit-panel.active { display: block; }

    /* Sticky warning */
    .trig-warning {
        position: sticky; top: 70px; z-index: 60; color: #b02a37; font-weight: 600; font-size: 0.9rem;
        padding: 10px 16px; background: #fff3f3; border: 1px solid #f5c6cb; border-radius: 8px;
        margin-bottom: 18px; display: none;
    }

    .trig-layout { display: flex; flex-wrap: wrap; gap: 30px; align-items: flex-start; }
    .sec-title { color: #2c5f7c; font-weight: 700; font-size: 1rem; margin: 0 0 12px; }

    /* ===== Circle ===== */
    .trig-circle-wrap { position: relative; width: 560px; height: 560px; flex-shrink: 0; }
    .trig-svg { position: absolute; inset: 0; }
    .pt-dot { stroke: #fff; stroke-width: 1.5; }
    .axis { stroke: #9db4c1; stroke-width: 1.5; }
    .axis-lbl { font: italic 700 16px 'Times New Roman', serif; fill: #2c5f7c; }

    .tri-hyp, .tri-sin, .tri-cos {
        stroke-dasharray: 1; stroke-dashoffset: 1; opacity: 0; fill: none;
        transition: stroke-dashoffset .5s ease, opacity .25s ease;
    }
    .tri-hyp { stroke: #2c5f7c; stroke-width: 2.5; }
    .tri-sin { stroke: #e74c3c; stroke-width: 2.5; transition-delay: .35s; }
    .tri-cos { stroke: #e6b000; stroke-width: 3; transition-delay: .6s; }
    .tri-hyp.show, .tri-sin.show, .tri-cos.show { stroke-dashoffset: 0; opacity: .95; }

    .deg-input {
        position: absolute; width: 44px; height: 28px; transform: translate(-50%, -50%);
        text-align: center; border: 2px solid #cfdce4; border-radius: 6px;
        background: #fff; font-size: 0.85rem; font-weight: 700; color: #2c5f7c; z-index: 5;
    }
    .deg-input:focus { outline: none; border-color: #e67e22; box-shadow: 0 0 7px rgba(230,126,34,.25); }
    .deg-input.correct { border-color: #2ecc71 !important; background: #eafaf1 !important; }
    .deg-input.wrong { border-color: #e74c3c !important; background: #fdf2f2 !important; }

    .rad-chip {
        position: absolute; transform: translate(-50%, -50%); z-index: 4;
        font-size: 0.82rem; color: #1e7e44; font-weight: 700; opacity: 0;
        transition: opacity .3s ease; pointer-events: none; white-space: nowrap;
    }
    .rad-chip.show { opacity: 1; }

    /* fraction display (radian) */
    .cfrac { display: inline-flex; flex-direction: column; align-items: center; vertical-align: middle; line-height: 1.05; }
    .cf-n { border-bottom: 1.4px solid currentColor; padding: 0 4px; }
    .cf-d { padding: 0 4px; }
    .cf-whole { vertical-align: middle; }

    /* ===== Table ===== */
    .trig-table-area { flex: 1; min-width: 320px; }
    .trig-table-scroll { overflow-x: auto; border-radius: 8px; }
    .trig-table { border-collapse: collapse; font-size: 0.82rem; }
    .trig-table th, .trig-table td { border: 1px solid #b9cad6; text-align: center; }
    .trig-table thead th {
        background: #2c5f7c; color: #fff; padding: 6px 4px; font-weight: 700; white-space: nowrap; min-width: 46px;
    }
    .trig-table thead th.gold { color: #ffd54a; }
    .trig-table th.corner { background: #234d63; min-width: 54px; line-height: 1.2; }
    .trig-table td.rowh, .trig-table th.rowh {
        background: #2c5f7c; color: #fff; font-weight: 700; font-style: italic; white-space: nowrap; padding: 4px 10px;
    }
    .trig-table tr.rad-row td { background: #dfe8ef; color: #234d63; font-weight: 600; padding: 5px 4px; }
    .trig-table tbody td { background: #eef3f7; padding: 3px; }
    .cell-input {
        width: 52px; height: 30px; text-align: center; border: 1.5px solid #cfdce4; border-radius: 5px;
        background: #fff; font-size: 0.8rem; font-weight: 600; color: #2c5f7c;
    }
    .cell-input:focus { outline: none; border-color: #e67e22; box-shadow: 0 0 6px rgba(230,126,34,.25); }
    .cell-input.correct { border-color: #2ecc71 !important; background: #eafaf1 !important; }
    .cell-input.wrong { border-color: #e74c3c !important; background: #fdf2f2 !important; }

    /* symbol + clear buttons */
    .sym-row { display: flex; gap: 10px; margin-top: 14px; align-items: center; }
    .sym-btn {
        width: 44px; height: 40px; border: none; border-radius: 8px; background: #2c5f7c; color: #fff;
        font-size: 1.15rem; font-weight: 700; cursor: pointer; transition: background .2s;
    }
    .sym-btn:hover { background: #234d63; }
    .sym-hint { font-size: 0.8rem; color: #6b8a99; font-style: italic; }
    .kit-btn {
        padding: 9px 26px; border: 1px solid #e3a9a1; border-radius: 8px; cursor: pointer;
        font-weight: 600; font-size: 0.9rem; color: #c0392b; background: #fff; transition: background .2s;
    }
    .kit-btn:hover { background: #fdf2f2; }

    .placeholder-box {
        padding: 40px; text-align: center; color: #6b8a99; font-style: italic;
        border: 2px dashed #cdd9e1; border-radius: 12px;
    }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

<div class="kit-container">
    <div class="kit-title">Trigonometri 1 &mdash; Lingkaran Satuan &amp; Tabel Perbandingan</div>
    <hr class="kit-title-bar">

    @* <div class="kit-tabs">
        <button class="kit-tab active" onclick="switchTab('kit')">KIT</button>
        <button class="kit-tab" onclick="switchTab('contoh')">Contoh Soal</button>
    </div> *@

    <!-- ========================= KIT ========================= -->
    <div class="kit-panel active" id="panel-kit">

        <div class="trig-warning" id="trigWarning">Perbaiki lagi &mdash; masih ada isian yang belum sesuai.</div>

        <div class="trig-layout">
            <!-- ===== Lingkaran ===== -->
            <div>
                <div class="sec-title">Isi derajat di tiap titik</div>
                <div class="trig-circle-wrap">
                    <svg class="trig-svg" width="560" height="560" viewBox="0 0 560 560">
                        <circle cx="280" cy="280" r="180" fill="#f7fbfd" stroke="#c7d6df" stroke-width="2" />
                        <line class="axis" x1="72" y1="280" x2="488" y2="280" />
                        <line class="axis" x1="280" y1="72" x2="280" y2="488" />
                        <polygon points="488,280 478,275 478,285" fill="#9db4c1" />
                        <polygon points="280,72 275,82 285,82" fill="#9db4c1" />
                        <text class="axis-lbl" x="494" y="286">x</text>
                        <text class="axis-lbl" x="286" y="70">y</text>

                        @for (int i = 0; i < cdegs.Length; i++)
                        {
                            int d = cdegs[i];
                            double rad = d * Math.PI / 180.0;
                            double dx = cx + R * Math.Cos(rad);
                            double dy = cy - R * Math.Sin(rad);
                            <line class="tri-hyp" id="hyp-@d" x1="@F(cx)" y1="@F(cy)" x2="@F(dx)" y2="@F(dy)" pathLength="1" />
                            <line class="tri-sin" id="sin-@d" x1="@F(dx)" y1="@F(dy)" x2="@F(dx)" y2="@F(cy)" pathLength="1" />
                            <line class="tri-cos" id="cos-@d" x1="@F(dx)" y1="@F(cy)" x2="@F(cx)" y2="@F(cy)" pathLength="1" />
                        }
                        @for (int i = 0; i < cdegs.Length; i++)
                        {
                            int d = cdegs[i];
                            double rad = d * Math.PI / 180.0;
                            double dx = cx + R * Math.Cos(rad);
                            double dy = cy - R * Math.Sin(rad);
                            <circle class="pt-dot" cx="@F(dx)" cy="@F(dy)" r="5.5" fill="@(IsRed(d) ? "#e74c3c" : "#2c5f7c")" />
                        }
                    </svg>

                    @for (int i = 0; i < cdegs.Length; i++)
                    {
                        int d = cdegs[i];
                        double rad = d * Math.PI / 180.0;
                        double ix = cx + RI * Math.Cos(rad);
                        double iy = cy - RI * Math.Sin(rad);
                        double rx = cx + RR * Math.Cos(rad);
                        double ry = cy - RR * Math.Sin(rad);
                        <input class="deg-input" type="text" inputmode="numeric" maxlength="3"
                               data-deg="@d" data-alt="@(d == 0 ? "360" : "")"
                               style="left:@(F(ix))px;top:@(F(iy))px;" />
                        <div class="rad-chip" id="chip-@d" style="left:@(F(rx))px;top:@(F(ry))px;">@Html.Raw(radHtml(radNum[i], radDen[i]))</div>
                    }
                </div>
            </div>

            <!-- ===== Tabel ===== -->
            <div class="trig-table-area">
                <div class="sec-title">Lengkapi nilai perbandingan</div>
                <div class="trig-table-scroll">
                    <table class="trig-table">
                        <thead>
                            <tr>
                                <th class="corner">Œ∏¬∞<br><span style="font-size:.8em;">Trig</span></th>
                                @for (int i = 0; i < degs.Length; i++)
                                {
                                    <th class="@(IsRed(degs[i]) ? "gold" : "")">@(degs[i])&deg;</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="rad-row">
                                <td class="rowh">rad</td>
                                @for (int i = 0; i < degs.Length; i++)
                                {
                                    <td>@Html.Raw(radHtml(radNum[i], radDen[i]))</td>
                                }
                            </tr>
                            @foreach (var row in rows)
                            {
                                <tr>
                                    <th class="rowh">@row.name</th>
                                    @for (int i = 0; i < degs.Length; i++)
                                    {
                                        <td><input class="cell-input" type="text" data-ans="@row.vals[i]" /></td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="sym-row">
                    <button class="sym-btn" type="button" onclick="insertSym('-')" title="minus">&minus;</button>
                    <button class="sym-btn" type="button" onclick="insertSym('‚àö')" title="akar">&#8730;</button>
                    <button class="sym-btn" type="button" onclick="insertSym('/')" title="pembagian">/</button>
                    <span class="sym-hint">klik sel dulu, lalu tekan simbol &bull; <b>td</b> = tak terdefinisi</span>
                </div>

                <div style="margin-top:18px;">
                    <button class="kit-btn" type="button" onclick="clearAll()">Clear</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ========================= CONTOH SOAL ========================= -->
    <div class="kit-panel" id="panel-contoh">
        <div class="placeholder-box">Contoh Soal &mdash; akan ditambahkan pada fase berikutnya.</div>
    </div>
</div>

@section Scripts {
<script>
    // ===== Tabs =====
    function switchTab(tab) {
        document.querySelectorAll('.kit-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.kit-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.kit-tab')[tab === 'kit' ? 0 : 1].classList.add('active');
        document.getElementById('panel-' + tab).classList.add('active');
    }

    // ===== Parser: string trigonometri -> angka (atau 'TD') =====
    function toNum(raw) {
        let t = (raw || '').toString().trim().toLowerCase().replace(/\s+/g, '');
        if (t === '') return null;
        t = t.replace(/[‚àí‚Äì‚Äî]/g, '-');
        if (/^(td|tak|takterdefinisi|takterdefinisikan|tidakterdefinisi|undefined|‚àû|-‚àû)$/.test(t)) return 'TD';
        t = t.replace(/,/g, '.');
        t = t.replace(/akar|sqrt/g, '‚àö');
        t = t.replace(/[√ó¬∑]/g, '*');
        t = t.replace(/‚àö\(([^)]*)\)/g, 'S($1)');
        t = t.replace(/‚àö(\d+(?:\.\d+)?)/g, 'S($1)');
        t = t.replace(/(\d|\))(S\()/g, '$1*$2');   // implicit perkalian, mis. 2‚àö3
        if (/[^0-9.+\-*/()S]/.test(t)) return NaN;
        const expr = t.replace(/S/g, 'Math.sqrt');
        try {
            const v = Function('"use strict";return(' + expr + ')')();
            return (typeof v === 'number' && isFinite(v)) ? v : NaN;
        } catch (e) { return NaN; }
    }

    // ===== Validasi sel tabel =====
    function judgeCell(inp) {
        const stu = toNum(inp.value);
        if (stu === null) return null;
        const ansStr = inp.dataset.ans;
        const truth = ansStr === 'td' ? 'TD' : toNum(ansStr);
        if (truth === 'TD') return stu === 'TD';
        if (stu === 'TD' || typeof stu !== 'number' || isNaN(stu)) return false;
        return Math.abs(stu - truth) < 1e-3;
    }
    function validateCell(inp) {
        const res = judgeCell(inp);
        inp.classList.toggle('correct', res === true);
        inp.classList.toggle('wrong', res === false);
        refresh();
    }

    // ===== Validasi titik lingkaran =====
    function setShow(id, on) { const e = document.getElementById(id); if (e) e.classList.toggle('show', on); }
    function revealPoint(d, on) {
        setShow('hyp-' + d, on); setShow('sin-' + d, on); setShow('cos-' + d, on);
        setShow('chip-' + d, on);
    }
    function validateDeg(inp) {
        const d = parseInt(inp.dataset.deg, 10);
        const raw = inp.value.trim();
        if (raw === '') { inp.classList.remove('correct', 'wrong'); revealPoint(d, false); refresh(); return; }
        const v = parseInt(raw, 10);
        const alt = inp.dataset.alt ? parseInt(inp.dataset.alt, 10) : null;
        const ok = v === d || (alt !== null && v === alt);
        inp.classList.toggle('correct', ok);
        inp.classList.toggle('wrong', !ok);
        revealPoint(d, ok);
        refresh();
    }

    // ===== Warning banner =====
    function refresh() {
        const anyWrong = document.querySelector('.cell-input.wrong, .deg-input.wrong');
        document.getElementById('trigWarning').style.display = anyWrong ? 'block' : 'none';
    }

    // ===== Tombol simbol =====
    let lastCell = null;
    function insertSym(sym) {
        const el = lastCell;
        if (!el) return;
        const s = el.selectionStart ?? el.value.length;
        const e = el.selectionEnd ?? el.value.length;
        el.value = el.value.slice(0, s) + sym + el.value.slice(e);
        const pos = s + sym.length;
        el.focus();
        try { el.setSelectionRange(pos, pos); } catch (_) {}
        validateCell(el);
    }

    // ===== Clear =====
    function clearAll() {
        document.querySelectorAll('.cell-input, .deg-input').forEach(i => {
            i.value = ''; i.classList.remove('correct', 'wrong');
        });
        document.querySelectorAll('.tri-hyp, .tri-sin, .tri-cos, .rad-chip').forEach(e => e.classList.remove('show'));
        refresh();
    }

    // ===== Wire up =====
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.cell-input').forEach(inp => {
            inp.addEventListener('focus', () => { lastCell = inp; });
            inp.addEventListener('input', () => validateCell(inp));
        });
        document.querySelectorAll('.deg-input').forEach(inp => {
            inp.addEventListener('input', () => validateDeg(inp));
        });
    });
</script>
}
