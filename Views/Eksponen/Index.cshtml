@{
    ViewData["Title"] = "Pembelajaran Eksponen";
}

<style>
    .kit-container { padding: 30px 35px; }
    .kit-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: #2c5f7c;
    }
    .kit-title-bar {
        border: none;
        border-top: 3px solid #e67e22;
        width: 60px;
        margin: 0 0 25px 0;
    }

    /* Tabs */
    .kit-tabs { display: flex; gap: 0; margin-bottom: 0; }
    .kit-tab {
        padding: 12px 30px;
        background: #dce6ec;
        color: #2c5f7c;
        border: none;
        cursor: pointer;
        font-weight: bold;
        font-size: 1rem;
        border-radius: 10px 10px 0 0;
        transition: background 0.3s, color 0.3s;
    }
    .kit-tab:hover { background: #c5d5df; }
    .kit-tab.active { background: #2c5f7c; color: #fff; }
    .kit-panel {
        display: none;
        background: #fff;
        border: 2px solid #2c5f7c;
        border-radius: 0 10px 10px 10px;
        padding: 30px 28px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .kit-panel.active { display: block; animation: fadeIn 0.4s ease; }

    /* Steps */
    .exp-step { margin-bottom: 26px; }
    .exp-step.is-hidden { display: none; }
    .exp-step-label {
        font-weight: 700;
        font-size: 0.95rem;
        color: #2c5f7c;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .exp-step-num {
        display: inline-flex; align-items: center; justify-content: center;
        width: 24px; height: 24px; border-radius: 50%;
        background: #e67e22; color: #fff; font-size: 0.8rem; flex-shrink: 0;
    }

    /* Equation pieces */
    .exp-eq { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; }
    .base {
        font-family: 'Times New Roman', Georgia, serif;
        font-style: italic;
        font-size: 1.7rem;
        color: #2c5f7c;
        position: relative;
        line-height: 1;
    }
    .base .sup {
        font-size: 0.62em;
        position: relative;
        top: -0.7em;
        margin-left: 1px;
    }
    .op { font-size: 1.5rem; color: #555; font-weight: 600; }

    .pangkat-input {
        width: 40px; height: 30px; text-align: center;
        border: 2px solid #d0dce4; border-radius: 6px;
        font-size: 0.95rem; font-weight: bold; color: #2c5f7c;
        background: #f8fafb; transition: border-color .3s, box-shadow .3s, background .3s;
    }
    .pangkat-input:focus {
        outline: none; border-color: #e67e22;
        box-shadow: 0 0 8px rgba(230,126,34,0.25); background: #fff;
    }
    .pangkat-input.correct { border-color: #2ecc71 !important; background: #eafaf1 !important; }
    .pangkat-input.wrong { border-color: #e74c3c !important; background: #fdf2f2 !important; }

    /* Persamaan jawaban: a^( [pangkat] [tanda] [pangkat] ) */
    .answer-exp { display: inline-flex; align-items: center; gap: 6px; position: relative; top: -14px; }
    .op-input { width: 36px !important; color: #e67e22; }

    /* Expansion boxes */
    .expand-box {
        display: inline-flex; flex-wrap: wrap; align-items: center; gap: 5px;
        min-height: 44px; min-width: 70px; padding: 6px 14px;
        border: 2px dashed #d0dce4; border-radius: 8px; background: #f8fafb;
    }
    .a-term {
        font-family: 'Times New Roman', Georgia, serif; font-style: italic;
        font-size: 1.4rem; color: #2c5f7c;
    }
    .a-term.pop { animation: pop .3s ease; }
    .a-term.one { font-style: normal; }   /* angka "1" pemula pada pembagian */
    .dot { color: #999; font-weight: bold; }
    .exp-empty { color: #bbb; font-style: italic; font-size: 0.85rem; }

    /* Fraction (pembagian) */
    .frac { display: inline-flex; flex-direction: column; align-items: center; gap: 4px; }
    .frac .frac-line { width: 100%; height: 3px; background: #2c5f7c; border-radius: 2px; }

    /* Buttons */
    .kit-btn-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 12px; }
    .kit-btn {
        padding: 8px 22px; border: none; border-radius: 8px; cursor: pointer;
        font-weight: 600; font-size: 0.9rem; color: #fff;
        background: #2c5f7c; transition: transform .15s, box-shadow .2s, background .2s;
    }
    .kit-btn:hover { background: #234d63; box-shadow: 0 3px 10px rgba(44,95,124,0.3); }
    .kit-btn:active { transform: translateY(1px); }
    .kit-btn.accent { background: #e67e22; }
    .kit-btn.accent:hover { background: #cf6f1c; box-shadow: 0 3px 10px rgba(230,126,34,0.35); }
    .kit-btn.ghost { background: #fff; color: #c0392b; border: 1px solid #e3a9a1; }
    .kit-btn.ghost:hover { background: #fdf2f2; box-shadow: none; }

    .counter-pill {
        display: inline-block; font-size: 0.78rem; font-weight: 600;
        padding: 2px 10px; border-radius: 12px; background: #eef3f6; color: #2c5f7c;
        margin-left: 6px;
    }

    /* Feedback */
    .exp-feedback {
        font-size: 0.85rem; font-weight: 600; margin-top: 10px; min-height: 20px;
        opacity: 0; transition: opacity .3s;
    }
    .exp-feedback.show { opacity: 1; }
    .exp-feedback.benar { color: #2ecc71; }
    .exp-feedback.salah { color: #e74c3c; }
    .exp-feedback.info { color: #6b8a99; }

    .final-banner {
        margin-top: 8px; padding: 18px 22px; border-radius: 10px;
        background: linear-gradient(135deg, #eafaf1 0%, #d7f5e6 100%);
        border: 1px solid #9fe0bd; text-align: center;
        animation: fadeIn .4s ease;
    }
    .final-banner .formula {
        font-family: 'Times New Roman', Georgia, serif; font-size: 1.6rem;
        color: #1e7e44; font-style: italic;
    }
    .final-banner .formula sup { font-size: 0.62em; }
    .final-banner .caption { font-size: 0.85rem; color: #2c7a4f; margin-top: 6px; }

    @@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes pop { 0% { transform: scale(0.3); opacity: 0; } 70% { transform: scale(1.2); } 100% { transform: scale(1); opacity: 1; } }
</style>

<div class="kit-container">
    <div class="kit-title">Pembelajaran Eksponen &mdash; Sifat-Sifat Eksponen</div>
    <hr class="kit-title-bar">

    <div class="kit-tabs">
        <button class="kit-tab active" onclick="switchTab('kali')">Perkalian</button>
        <button class="kit-tab" onclick="switchTab('bagi')">Pembagian</button>
    </div>

    <!-- ========================= PERKALIAN ========================= -->
    <div class="kit-panel active" id="panel-kali">

        <!-- Step 1: soal -->
        <div class="exp-step">
            <div class="exp-step-label"><span class="exp-step-num">1</span> Isi pangkat (kotak kosong) dengan angka</div>
            <div class="exp-eq">
                <span class="base">a<span class="sup"><input type="number" min="1" max="9" class="pangkat-input" id="kali-n"></span></span>
                <span class="op">&times;</span>
                <span class="base">a<span class="sup"><input type="number" min="1" max="9" class="pangkat-input" id="kali-m"></span></span>
            </div>
            <div class="exp-feedback info" id="kali-fb-soal"></div>
        </div>

        <!-- Step 2: penjabaran -->
        <div class="exp-step is-hidden" id="kali-penjabaran">
            <div class="exp-step-label"><span class="exp-step-num">2</span> Jabarkan menjadi perkalian berulang</div>
            <div class="exp-eq">
                <span class="op">=</span>
                <span class="expand-box" id="kali-box-left"></span>
                <span class="op">&times;</span>
                <span class="expand-box" id="kali-box-right"></span>
            </div>
            <div class="kit-btn-row">
                <button class="kit-btn" onclick="addA('kali','left')">Kiri <span class="counter-pill" id="kali-cnt-left">0</span></button>
                <button class="kit-btn" onclick="addA('kali','right')">Kanan <span class="counter-pill" id="kali-cnt-right">0</span></button>
            </div>
            <div class="exp-feedback info" id="kali-fb-penjabaran"></div>
        </div>

        <!-- Step 3: hasil -->
        <div class="exp-step is-hidden" id="kali-hasil-sec">
            <div class="exp-step-label"><span class="exp-step-num">3</span> Gabungkan semua faktor menjadi hasil</div>
            <div class="exp-eq">
                <span class="op">=</span>
                <span class="expand-box" id="kali-box-hasil"></span>
            </div>
            <div class="kit-btn-row">
                <button class="kit-btn accent" onclick="addHasil('kali')">Hasil <span class="counter-pill" id="kali-cnt-hasil">0</span></button>
            </div>
            <div class="exp-feedback info" id="kali-fb-hasil"></div>
        </div>

        <!-- Step 4: jawaban pangkat (persamaan m + n) -->
        <div class="exp-step is-hidden" id="kali-jawab-sec">
            <div class="exp-step-label"><span class="exp-step-num">4</span> Tuliskan sebagai satu pangkat: isi pangkat, tanda, pangkat</div>
            <div class="exp-eq">
                <span class="op">=</span>
                <span class="base" style="font-size:2rem;">a</span>
                <span class="answer-exp">
                    <input type="number" class="pangkat-input" id="kali-jawab-a">
                    <input type="text" class="pangkat-input op-input" id="kali-jawab-op" maxlength="1">
                    <input type="number" class="pangkat-input" id="kali-jawab-b">
                </span>
            </div>
            <div class="exp-feedback" id="kali-fb-jawab"></div>
        </div>

        <!-- Final -->
        <div class="exp-step is-hidden" id="kali-final"></div>

        <div class="kit-btn-row" style="margin-top:18px;">
            <button class="kit-btn ghost" onclick="clearTab('kali')">Clear</button>
        </div>
    </div>

    <!-- ========================= PEMBAGIAN ========================= -->
    <div class="kit-panel" id="panel-bagi">

        <!-- Step 1: soal -->
        <div class="exp-step">
            <div class="exp-step-label"><span class="exp-step-num">1</span> Isi pangkat (kotak kosong) dengan angka</div>
            <div class="exp-eq">
                <div class="frac">
                    <span class="base">a<span class="sup"><input type="number" min="1" max="9" class="pangkat-input" id="bagi-n"></span></span>
                    <div class="frac-line"></div>
                    <span class="base">a<span class="sup"><input type="number" min="1" max="9" class="pangkat-input" id="bagi-m"></span></span>
                </div>
            </div>
            <div class="exp-feedback info" id="bagi-fb-soal">Catatan: pangkat atas boleh lebih kecil dari bawah &mdash; hasilnya akan berpangkat negatif.</div>
        </div>

        <!-- Step 2: penjabaran -->
        <div class="exp-step is-hidden" id="bagi-penjabaran">
            <div class="exp-step-label"><span class="exp-step-num">2</span> Jabarkan menjadi perkalian berulang</div>
            <div class="exp-eq">
                <span class="op">=</span>
                <div class="frac">
                    <span class="expand-box" id="bagi-box-atas"></span>
                    <div class="frac-line"></div>
                    <span class="expand-box" id="bagi-box-bawah"></span>
                </div>
            </div>
            <div class="kit-btn-row">
                <button class="kit-btn" onclick="addA('bagi','atas')">Atas <span class="counter-pill" id="bagi-cnt-atas">0</span></button>
                <button class="kit-btn" onclick="addA('bagi','bawah')">Bawah <span class="counter-pill" id="bagi-cnt-bawah">0</span></button>
            </div>
            <div class="exp-feedback info" id="bagi-fb-penjabaran"></div>
        </div>

        <!-- Step 3: hasil (pecahan — coret faktor yang sama) -->
        <div class="exp-step is-hidden" id="bagi-hasil-sec">
            <div class="exp-step-label"><span class="exp-step-num">3</span> Coret faktor yang sama, tuliskan sisa di atas / bawah</div>
            <div class="exp-eq">
                <span class="op">=</span>
                <div class="frac">
                    <span class="expand-box" id="bagi-box-hasilAtas"></span>
                    <div class="frac-line"></div>
                    <span class="expand-box" id="bagi-box-hasilBawah"></span>
                </div>
            </div>
            <div class="kit-btn-row">
                <button class="kit-btn accent" onclick="addHasilFrac('atas')">Hasil Atas <span class="counter-pill" id="bagi-cnt-hasilAtas">0</span></button>
                <button class="kit-btn accent" onclick="addHasilFrac('bawah')">Hasil Bawah <span class="counter-pill" id="bagi-cnt-hasilBawah">0</span></button>
            </div>
            <div class="exp-feedback info" id="bagi-fb-hasil"></div>
        </div>

        <!-- Step 4: jawaban pangkat (persamaan m − n) -->
        <div class="exp-step is-hidden" id="bagi-jawab-sec">
            <div class="exp-step-label"><span class="exp-step-num">4</span> Tuliskan sebagai satu pangkat: isi pangkat, tanda, pangkat</div>
            <div class="exp-eq">
                <span class="op">=</span>
                <span class="base" style="font-size:2rem;">a</span>
                <span class="answer-exp">
                    <input type="number" class="pangkat-input" id="bagi-jawab-a">
                    <input type="text" class="pangkat-input op-input" id="bagi-jawab-op" maxlength="1">
                    <input type="number" class="pangkat-input" id="bagi-jawab-b">
                </span>
            </div>
            <div class="exp-feedback" id="bagi-fb-jawab"></div>
        </div>

        <!-- Final -->
        <div class="exp-step is-hidden" id="bagi-final"></div>

        <div class="kit-btn-row" style="margin-top:18px;">
            <button class="kit-btn ghost" onclick="clearTab('bagi')">Clear</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ===== State & configuration =====
    const ST = {
        kali: { n: null, m: null, left: 0, right: 0, hasil: 0 },
        bagi: { n: null, m: null, atas: 0, bawah: 0, hasilAtas: 0, hasilBawah: 0 }
    };
    const CFG = {
        kali: {
            sides: ['left', 'right'],
            target: (s, side) => side === 'left' ? s.n : s.m,
            expectedHasil: s => s.n + s.m,
            answer: s => s.n + s.m
        },
        bagi: {
            sides: ['atas', 'bawah'],
            target: (s, side) => side === 'atas' ? s.n : s.m,
            answer: s => s.n - s.m
        }
    };

    function el(id) { return document.getElementById(id); }
    function show(id, on) { el(id).classList.toggle('is-hidden', !on); }
    function fb(id, msg, type) {
        const e = el(id);
        e.textContent = msg;
        e.className = 'exp-feedback show ' + (type || 'info');
        if (!msg) e.classList.remove('show');
    }

    // ===== Tabs =====
    function switchTab(tab) {
        document.querySelectorAll('.kit-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.kit-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.kit-tab')[tab === 'kali' ? 0 : 1].classList.add('active');
        el('panel-' + tab).classList.add('active');
    }

    // ===== Render perkalian berulang =====
    function dots(n) {
        if (n <= 0) return '<span class="exp-empty">belum ada</span>';
        let html = '';
        for (let i = 0; i < n; i++) {
            if (i > 0) html += '<span class="dot">&middot;</span>';
            html += '<span class="a-term' + (i === n - 1 ? ' pop' : '') + '">a</span>';
        }
        return html;
    }
    // Pembagian: selalu diawali "1", lalu n buah "· a" (1 · a · a ...). n=0 → "1".
    function dotsOne(n) {
        let html = '<span class="a-term one">1</span>';
        for (let i = 0; i < n; i++) {
            html += '<span class="dot">&middot;</span>';
            html += '<span class="a-term' + (i === n - 1 ? ' pop' : '') + '">a</span>';
        }
        return html;
    }
    function renderBox(tab, side) {
        const n = ST[tab][side];
        el(tab + '-box-' + side).innerHTML = (tab === 'bagi') ? dotsOne(n) : dots(n);
        if (el(tab + '-cnt-' + side)) el(tab + '-cnt-' + side).textContent = n;
    }

    // ===== Pembagian: hasil berupa pecahan (Hasil Atas / Hasil Bawah) =====
    // Sisa faktor setelah dicoret: atas = maks(0, n-m), bawah = maks(0, m-n).
    // Sisi yang habis dicoret otomatis jadi "1" (dotsOne(0)).
    function resultTarget(side) {
        const s = ST.bagi;
        if (s.n == null) return NaN;
        return side === 'atas' ? Math.max(0, s.n - s.m) : Math.max(0, s.m - s.n);
    }
    function renderResultBagi() {
        [['atas', 'hasilAtas'], ['bawah', 'hasilBawah']].forEach(([side, key]) => {
            const count = ST.bagi[key];
            el('bagi-box-' + key).innerHTML = dotsOne(count);
            el('bagi-cnt-' + key).textContent = count;
        });
    }

    // ===== Reset langkah 2-4 =====
    function resetSteps(tab) {
        const s = ST[tab];
        if (tab === 'kali') {
            s.left = s.right = s.hasil = 0;
            renderBox('kali', 'left'); renderBox('kali', 'right'); renderBox('kali', 'hasil');
        } else {
            s.atas = s.bawah = s.hasilAtas = s.hasilBawah = 0;
            renderBox('bagi', 'atas'); renderBox('bagi', 'bawah'); renderResultBagi();
        }
        ['-jawab-a', '-jawab-op', '-jawab-b'].forEach(suf => {
            const e = el(tab + suf);
            if (e) { e.value = ''; e.classList.remove('correct', 'wrong'); }
        });
        show(tab + '-hasil-sec', false);
        show(tab + '-jawab-sec', false);
        show(tab + '-final', false);
        fb(tab + '-fb-penjabaran', '', 'info');
        fb(tab + '-fb-hasil', '', 'info');
        fb(tab + '-fb-jawab', '', 'info');
    }

    // ===== Step 1: baca pangkat =====
    function readPangkat(tab) {
        const s = ST[tab];
        const nv = parseInt(el(tab + '-n').value);
        const mv = parseInt(el(tab + '-m').value);
        const validN = Number.isInteger(nv) && nv >= 1;
        const validM = Number.isInteger(mv) && mv >= 1;
        el(tab + '-n').classList.toggle('correct', validN);
        el(tab + '-m').classList.toggle('correct', validM);

        s.n = s.m = null;           // reset dulu; diisi lagi bila valid
        resetSteps(tab);            // butuh n=null agar kotak hasil belum menebak "1"

        if (!validN || !validM) {
            show(tab + '-penjabaran', false);
            if (el(tab + '-n').value || el(tab + '-m').value)
                fb(tab + '-fb-soal', 'Isi kedua pangkat dengan bilangan bulat positif.', 'info');
            else fb(tab + '-fb-soal', '', 'info');
            return;
        }
        s.n = nv; s.m = mv;
        // Pembagian: atas boleh <, =, atau > bawah (aturan 11-12 KIT).
        if (tab === 'bagi')
            fb('bagi-fb-soal', 'Pangkat atas boleh lebih kecil dari bawah — hasilnya akan berpangkat negatif.', 'info');
        else
            fb(tab + '-fb-soal', '', 'info');
        show(tab + '-penjabaran', true);
        checkPenjabaran(tab);
    }

    // ===== Step 2: tambah huruf a =====
    function addA(tab, side) {
        const s = ST[tab];
        if (s.n == null) return;
        const target = CFG[tab].target(s, side);
        if (s[side] >= target) {
            fb(tab + '-fb-penjabaran', 'Belum sesuai definisi eksponen (jumlah a sudah sama dengan pangkat).', 'salah');
            return;
        }
        s[side]++;
        renderBox(tab, side);
        checkPenjabaran(tab);
    }
    function checkPenjabaran(tab) {
        const s = ST[tab];
        const done = CFG[tab].sides.every(sd => s[sd] === CFG[tab].target(s, sd));
        if (done) {
            fb(tab + '-fb-penjabaran', 'Sesuai definisi eksponen ✓', 'benar');
            show(tab + '-hasil-sec', true);
            if (tab === 'bagi') { renderResultBagi(); checkHasilBagi(); }
        } else {
            const parts = CFG[tab].sides.map(sd => sd + ': ' + s[sd] + '/' + CFG[tab].target(s, sd));
            fb(tab + '-fb-penjabaran', 'Klik tombol hingga jumlah a sesuai pangkat — ' + parts.join(', '), 'info');
            show(tab + '-hasil-sec', false);
            show(tab + '-jawab-sec', false);
            show(tab + '-final', false);
        }
    }

    // ===== Step 3 (perkalian): hasil satu kotak =====
    function addHasil(tab) {
        const s = ST[tab];
        const expected = CFG[tab].expectedHasil(s);
        if (s.hasil >= expected) {
            fb(tab + '-fb-hasil', 'Perbaiki lagi (jumlah a pada hasil sudah cukup).', 'salah');
            return;
        }
        s.hasil++;
        renderBox(tab, 'hasil');
        checkHasil(tab);
    }
    function checkHasil(tab) {
        const s = ST[tab];
        const expected = CFG[tab].expectedHasil(s);
        if (s.hasil === expected) {
            fb(tab + '-fb-hasil', 'Jumlah a pada hasil sesuai dengan jumlah a kiri (' + s.left + ') + a kanan (' + s.right + ') ✓', 'benar');
            show(tab + '-jawab-sec', true);
        } else {
            fb(tab + '-fb-hasil', 'Klik "Hasil" untuk menambahkan a. Jumlah sekarang: ' + s.hasil, 'info');
            show(tab + '-jawab-sec', false);
            show(tab + '-final', false);
        }
    }

    // ===== Step 3 (pembagian): hasil berupa pecahan =====
    function addHasilFrac(side) {
        const s = ST.bagi;
        if (s.n == null) return;
        const key = side === 'atas' ? 'hasilAtas' : 'hasilBawah';
        if (s[key] >= resultTarget(side)) {
            fb('bagi-fb-hasil', 'Perbaiki lagi (jumlah a pada hasil ' + side + ' sudah cukup).', 'salah');
            return;
        }
        s[key]++;
        renderResultBagi();
        checkHasilBagi();
    }
    function checkHasilBagi() {
        const s = ST.bagi;
        const done = s.hasilAtas === resultTarget('atas') && s.hasilBawah === resultTarget('bawah');
        if (done) {
            let msg;
            if (s.n > s.m) msg = 'Faktor bawah habis dicoret, sisa ' + (s.n - s.m) + ' faktor a di atas ✓';
            else if (s.n < s.m) msg = 'Faktor atas habis dicoret, sisa ' + (s.m - s.n) + ' faktor a di bawah ✓';
            else msg = 'Semua faktor saling mencoret, hasilnya 1 ✓';
            fb('bagi-fb-hasil', msg, 'benar');
            show('bagi-jawab-sec', true);
        } else {
            fb('bagi-fb-hasil', 'Coret faktor yang sama, lalu klik "Hasil Atas" / "Hasil Bawah" untuk sisa faktornya.', 'info');
            show('bagi-jawab-sec', false);
            show('bagi-final', false);
        }
    }

    // ===== Step 4: jawaban pangkat sebagai persamaan (m + n / m − n) =====
    function checkJawab(tab) {
        const s = ST[tab];
        if (s.n == null) return;
        const aEl = el(tab + '-jawab-a'), opEl = el(tab + '-jawab-op'), bEl = el(tab + '-jawab-b');
        const av = parseInt(aEl.value);
        const bv = parseInt(bEl.value);
        const opRaw = (opEl.value || '').trim();
        const wantOp = tab === 'kali' ? '+' : '−';

        const filledA = aEl.value.trim() !== '';
        const filledB = bEl.value.trim() !== '';
        const filledOp = opRaw !== '';
        const okA = av === s.n;
        const okB = bv === s.m;
        const okOp = tab === 'kali' ? (opRaw === '+') : (opRaw === '-' || opRaw === '−');

        [[aEl, okA, filledA], [opEl, okOp, filledOp], [bEl, okB, filledB]].forEach(([e, ok, filled]) => {
            e.classList.remove('correct', 'wrong');
            if (filled) e.classList.add(ok ? 'correct' : 'wrong');
        });

        if (!(filledA && filledOp && filledB)) {
            fb(tab + '-fb-jawab', '', 'info');
            show(tab + '-final', false);
            return;
        }
        if (okA && okOp && okB) {
            fb(tab + '-fb-jawab', 'Jawaban anda benar ✓', 'benar');
            showFinal(tab);
        } else {
            fb(tab + '-fb-jawab', 'Perbaiki lagi — isi: pangkat pertama, tanda "' + wantOp + '", pangkat kedua.', 'salah');
            show(tab + '-final', false);
        }
    }
    function showFinal(tab) {
        if (tab === 'kali') showFinalKali(); else showFinalBagi();
    }
    function showFinalKali() {
        const s = ST.kali;
        const formula =
            'a<sup>' + s.n + '</sup> &times; a<sup>' + s.m + '</sup> = ' +
            'a<sup>' + s.n + '+' + s.m + '</sup> = a<sup>' + (s.n + s.m) + '</sup>';
        el('kali-final').innerHTML =
            '<div class="final-banner"><div class="formula">' + formula + '</div>' +
            '<div class="caption">Sifat: a<sup>n</sup> &times; a<sup>m</sup> = a<sup>n+m</sup></div></div>';
        show('kali-final', true);
    }
    function showFinalBagi() {
        const s = ST.bagi;
        const diff = s.n - s.m;
        const diffSup = diff < 0 ? '&minus;' + (-diff) : String(diff);
        let formula =
            'a<sup>' + s.n + '</sup> &divide; a<sup>' + s.m + '</sup> = ' +
            'a<sup>' + s.n + '&minus;' + s.m + '</sup> = a<sup>' + diffSup + '</sup>';
        let caption = 'Sifat: a<sup>n</sup> &divide; a<sup>m</sup> = a<sup>n&minus;m</sup>';
        if (diff < 0) {
            formula += ' = 1 / a<sup>' + (-diff) + '</sup>';
            caption += ' &mdash; pangkat negatif: a<sup>&minus;k</sup> = 1/a<sup>k</sup>';
        } else if (diff === 0) {
            formula += ' = 1';
            caption += ' &mdash; a<sup>0</sup> = 1';
        }
        el('bagi-final').innerHTML =
            '<div class="final-banner"><div class="formula">' + formula + '</div>' +
            '<div class="caption">' + caption + '</div></div>';
        show('bagi-final', true);
    }

    // ===== Clear =====
    function clearTab(tab) {
        const s = ST[tab];
        resetSteps(tab);
        if (s.n != null) { show(tab + '-penjabaran', true); checkPenjabaran(tab); }
    }

    // ===== Wire up =====
    document.addEventListener('DOMContentLoaded', function () {
        ['kali', 'bagi'].forEach(tab => {
            el(tab + '-n').addEventListener('input', () => readPangkat(tab));
            el(tab + '-m').addEventListener('input', () => readPangkat(tab));
            ['-jawab-a', '-jawab-op', '-jawab-b'].forEach(suf =>
                el(tab + suf).addEventListener('input', () => checkJawab(tab)));
        });
        renderBox('kali', 'left'); renderBox('kali', 'right'); renderBox('kali', 'hasil');
        renderBox('bagi', 'atas'); renderBox('bagi', 'bawah'); renderResultBagi();
    });
</script>
}
