@{
    ViewData["Title"] = "Fungsi Komposisi";
}

<style>
    .kit-container { padding: 30px 35px; }
    .kit-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: #2c5f7c;
    }
    .kit-title-bar {
        border: none;
        border-top: 3px solid #e67e22;
        width: 60px;
        margin: 0 0 25px 0;
    }

    /* Formula input area */
    .formula-area {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 20px;
        background: #fff;
        padding: 18px 22px;
        border-radius: 10px;
        border: 1px solid #e0e6eb;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }
    .formula-group {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .formula-group label {
        font-weight: 700;
        font-size: 1.05rem;
        color: #2c5f7c;
    }
    .formula-group input {
        width: 170px;
        padding: 8px 12px;
        border: 2px solid #d0dce4;
        border-radius: 8px;
        font-family: 'Courier New', monospace;
        font-size: 1rem;
        transition: all 0.3s;
        background: #f8fafb;
    }
    .formula-group input:focus {
        outline: none;
        border-color: #e67e22;
        box-shadow: 0 0 8px rgba(230,126,34,0.25);
        background: #fff;
    }
    .formula-hint {
        font-size: 0.82rem;
        color: #999;
        font-style: italic;
    }
    .formula-warning {
        color: #dc3545;
        font-weight: bold;
        font-size: 0.9rem;
        padding: 8px 15px;
        background: #fff3f3;
        border-radius: 6px;
        border: 1px solid #f5c6cb;
        display: none;
        margin-bottom: 15px;
        animation: shakeX 0.5s;
    }

    /* Tab navigation */
    .kit-tabs {
        display: flex;
        gap: 0;
        margin-bottom: 0;
    }
    .kit-tab {
        padding: 12px 30px;
        background: #dce6ec;
        color: #2c5f7c;
        border: none;
        cursor: pointer;
        font-weight: bold;
        font-size: 1rem;
        border-radius: 10px 10px 0 0;
        transition: all 0.3s;
    }
    .kit-tab:hover { background: #c5d5df; }
    .kit-tab.active {
        background: #2c5f7c;
        color: #fff;
    }
    .kit-panel {
        display: none;
        background: #fff;
        border: 2px solid #2c5f7c;
        border-radius: 0 10px 10px 10px;
        padding: 30px 20px;
        animation: fadeIn 0.5s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .kit-panel.active { display: block; }

    /* Ellipse diagram */
    .diagram-wrapper {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        gap: 0;
        padding: 20px 10px;
        position: relative;
        overflow-x: auto;
    }
    .ellipse-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 2;
    }
    .ellipse-label {
        font-weight: 700;
        font-size: 1.1rem;
        color: #2c5f7c;
        margin-bottom: 8px;
    }
    .ellipse-shape {
        width: 130px;
        background: linear-gradient(135deg, #2c5f7c 0%, #1e4a5f 100%);
        border-radius: 50% / 45%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 28px 12px;
        gap: 10px;
        position: relative;
        box-shadow: 0 4px 12px rgba(44,95,124,0.25);
        transition: transform 0.3s, box-shadow 0.3s;
        min-height: 260px;
    }
    .ellipse-shape:hover {
        transform: scale(1.03);
        box-shadow: 0 6px 18px rgba(44,95,124,0.35);
    }

    .ellipse-value {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        text-align: center;
        min-height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .ellipse-input {
        width: 72px;
        height: 32px;
        text-align: center;
        font-size: 0.95rem;
        font-weight: bold;
        border: 2px solid rgba(255,255,255,0.4);
        border-radius: 6px;
        background: rgba(255,255,255,0.12);
        color: #fff;
        transition: all 0.3s;
    }
    .ellipse-input::placeholder { color: rgba(255,255,255,0.35); }
    .ellipse-input:focus {
        outline: none;
        border-color: #e67e22;
        background: rgba(255,255,255,0.25);
        box-shadow: 0 0 8px rgba(230,126,34,0.4);
    }
    .ellipse-input.correct {
        border-color: #2ecc71 !important;
        background: rgba(46,204,113,0.3) !important;
        animation: pulseGreen 0.5s;
    }
    .ellipse-input.wrong {
        border-color: #e74c3c !important;
        background: rgba(231,76,60,0.3) !important;
        animation: shakeX 0.4s;
    }

    /* Arrow columns */
    .arrow-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        z-index: 1;
        margin: 0 -8px;
        padding-top: 32px;
    }
    .arrow-label-top {
        font-weight: 700;
        font-size: 0.9rem;
        color: #e67e22;
        margin-bottom: 4px;
        background: #fff;
        padding: 2px 8px;
        border-radius: 4px;
        border: 1px solid #f0d0a0;
    }
    .arrow-row {
        display: flex;
        align-items: center;
        height: 38px;
    }
    .arrow-line {
        width: 50px;
        height: 3px;
        background: linear-gradient(90deg, #e67e22, #d35400);
        position: relative;
        border-radius: 2px;
        opacity: 0;
        animation: arrowSlideIn 0.6s forwards;
    }
    .arrow-line::after {
        content: '';
        position: absolute;
        right: -7px;
        top: -5px;
        border: 7px solid transparent;
        border-left: 10px solid #d35400;
    }
    .arrow-row:nth-child(2) .arrow-line { animation-delay: 0.1s; }
    .arrow-row:nth-child(3) .arrow-line { animation-delay: 0.2s; }
    .arrow-row:nth-child(4) .arrow-line { animation-delay: 0.3s; }
    .arrow-row:nth-child(5) .arrow-line { animation-delay: 0.4s; }

    /* Feedback tooltip */
    .cell-feedback {
        position: absolute;
        font-size: 0.7rem;
        font-weight: bold;
        white-space: nowrap;
        padding: 2px 6px;
        border-radius: 4px;
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
        z-index: 10;
    }
    .cell-feedback.show { opacity: 1; }
    .cell-feedback.benar { color: #2ecc71; }
    .cell-feedback.salah { color: #e74c3c; }

    .input-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .input-wrapper .cell-feedback {
        position: relative;
        margin-top: 2px;
        font-size: 0.65rem;
    }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes arrowSlideIn {
        from { opacity: 0; width: 0; }
        to { opacity: 1; width: 50px; }
    }
    @@keyframes shakeX {
        0%, 100% { transform: translateX(0); }
        20% { transform: translateX(-5px); }
        40% { transform: translateX(5px); }
        60% { transform: translateX(-3px); }
        80% { transform: translateX(3px); }
    }
    @@keyframes pulseGreen {
        0% { transform: scale(1); }
        50% { transform: scale(1.1); }
        100% { transform: scale(1); }
    }
    @@keyframes ellipseEnter {
        from { opacity: 0; transform: scale(0.8); }
        to { opacity: 1; transform: scale(1); }
    }
    .ellipse-shape { animation: ellipseEnter 0.5s ease; }
    .ellipse-col:nth-child(1) .ellipse-shape { animation-delay: 0s; }
    .ellipse-col:nth-child(3) .ellipse-shape { animation-delay: 0.15s; }
    .ellipse-col:nth-child(5) .ellipse-shape { animation-delay: 0.3s; }
    .ellipse-col:nth-child(7) .ellipse-shape { animation-delay: 0.45s; }
</style>

