@{
    ViewData["Title"] = "Fungsi Komposisi";
}

<style>
    .kit-container { padding: 30px 35px; }
    .kit-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: #2c5f7c;
    }
    .kit-title-bar {
        border: none;
        border-top: 3px solid #e67e22;
        width: 60px;
        margin: 0 0 25px 0;
    }

    /* Warning */
    .formula-warning {
        color: #dc3545;
        font-weight: bold;
        font-size: 0.9rem;
        padding: 8px 15px;
        background: #fff3f3;
        border-radius: 6px;
        border: 1px solid #f5c6cb;
        display: none;
        margin-bottom: 15px;
    }

    /* Tab navigation */
    .kit-tabs { display: flex; gap: 0; margin-bottom: 0; }
    .kit-tab {
        padding: 12px 30px;
        background: #dce6ec;
        color: #2c5f7c;
        border: none;
        cursor: pointer;
        font-weight: bold;
        font-size: 1rem;
        border-radius: 10px 10px 0 0;
        transition: background 0.3s, color 0.3s;
    }
    .kit-tab:hover { background: #c5d5df; }
    .kit-tab.active { background: #2c5f7c; color: #fff; }
    .kit-panel {
        display: none;
        background: #fff;
        border: 2px solid #2c5f7c;
        border-radius: 0 10px 10px 10px;
        padding: 30px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .kit-panel.active { display: block; animation: fadeIn 0.4s ease; }

    /* Formula row above/below diagram */
    .formula-row {
        display: flex;
        justify-content: center;
        gap: 0;
        padding: 0 10px;
    }
    .formula-cell {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }
    .formula-cell.col-cell { width: 130px; flex-shrink: 0; }
    .formula-cell.arrow-cell { width: 104px; flex-shrink: 0; margin: 0 10px; }
    .formula-cell label {
        font-weight: 700;
        font-size: 0.85rem;
        color: #2c5f7c;
        white-space: nowrap;
    }
    .formula-cell input {
        width: 120px;
        padding: 6px 8px;
        border: 2px solid #d0dce4;
        border-radius: 8px;
        font-family: 'Courier New', monospace;
        font-size: 0.9rem;
        text-align: center;
        transition: border-color 0.3s, box-shadow 0.3s, background 0.3s;
        background: #f8fafb;
    }
    .formula-cell input:focus {
        outline: none;
        border-color: #e67e22;
        box-shadow: 0 0 8px rgba(230,126,34,0.25);
        background: #fff;
    }
    .formula-cell input.correct { border-color: #2ecc71 !important; background: #eafaf1 !important; }
    .formula-cell input.wrong { border-color: #e74c3c !important; background: #fdf2f2 !important; }
    .formula-cell .formula-feedback {
        font-size: 0.75rem;
        font-weight: 600;
        opacity: 0;
        transition: opacity 0.3s;
        white-space: nowrap;
    }
    .formula-cell .formula-feedback.show { opacity: 1; }
    .formula-cell .formula-feedback.benar { color: #2ecc71; }
    .formula-cell .formula-feedback.salah { color: #e74c3c; }
    .formula-hint-row {
        text-align: center;
        font-size: 0.78rem;
        color: #999;
        font-style: italic;
        padding: 0 10px;
    }

    /* Diagram layout */
    .diagram-wrapper {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        gap: 0;
        padding: 20px 10px 10px;
        overflow-x: auto;
    }
    .ellipse-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 2;
    }
    .ellipse-label {
        font-weight: 700;
        font-size: 1.1rem;
        color: #2c5f7c;
        margin-bottom: 8px;
    }
    .ellipse-shape {
        width: 130px;
        background: linear-gradient(135deg, #2c5f7c 0%, #1e4a5f 100%);
        border-radius: 50% / 45%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 28px 12px;
        gap: 10px;
        box-shadow: 0 4px 12px rgba(44,95,124,0.25);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        min-height: 260px;
        animation: ellipseEnter 0.5s ease both;
    }
    .ellipse-shape:hover {
        transform: scale(1.03);
        box-shadow: 0 6px 18px rgba(44,95,124,0.35);
    }
    .ellipse-col:nth-child(1) .ellipse-shape { animation-delay: 0s; }
    .ellipse-col:nth-child(3) .ellipse-shape { animation-delay: 0.15s; }
    .ellipse-col:nth-child(5) .ellipse-shape { animation-delay: 0.3s; }

    .ellipse-value {
        color: #fff; font-size: 1.1rem; font-weight: 700;
        text-align: center; min-height: 30px;
        display: flex; align-items: center; justify-content: center;
    }
    .ellipse-input {
        width: 72px; height: 32px; text-align: center;
        font-size: 0.95rem; font-weight: bold;
        border: 2px solid rgba(255,255,255,0.4); border-radius: 6px;
        background: rgba(255,255,255,0.12); color: #fff;
        transition: border-color 0.3s, background 0.3s, box-shadow 0.3s;
    }
    .ellipse-input::placeholder { color: rgba(255,255,255,0.35); }
    .ellipse-input:focus {
        outline: none; border-color: #e67e22;
        background: rgba(255,255,255,0.25);
        box-shadow: 0 0 8px rgba(230,126,34,0.4);
    }
    .ellipse-input.correct { border-color: #2ecc71 !important; background: rgba(46,204,113,0.3) !important; }
    .ellipse-input.wrong { border-color: #e74c3c !important; background: rgba(231,76,60,0.3) !important; }

    /* Arrow columns */
    .arrow-col {
        display: flex; flex-direction: column; align-items: center;
        gap: 10px; z-index: 1; margin: 0 10px; padding-top: 32px;
    }
    .arrow-label-top {
        font-weight: 700; font-size: 0.9rem; color: #e67e22;
        margin-bottom: 4px; background: #fff; padding: 2px 8px;
        border-radius: 4px; border: 1px solid #f0d0a0;
    }
    .arrow-row { display: flex; align-items: center; height: 38px; padding-right: 12px; }
    .arrow-line {
        width: 60px; height: 3px;
        background: linear-gradient(90deg, #e67e22, #d35400);
        position: relative; border-radius: 2px;
    }
    .arrow-line::after {
        content: ''; position: absolute; right: -8px; top: -5px;
        border: 7px solid transparent; border-left: 10px solid #d35400;
    }
    /* First arrow col: animate on load sequentially */
    .arrow-col[data-arrow="1"] .arrow-row .arrow-line {
        animation: arrowSlideIn 0.5s ease both;
    }
    .arrow-col[data-arrow="1"] .arrow-row:nth-child(2) .arrow-line { animation-delay: 0.1s; }
    .arrow-col[data-arrow="1"] .arrow-row:nth-child(3) .arrow-line { animation-delay: 0.2s; }
    .arrow-col[data-arrow="1"] .arrow-row:nth-child(4) .arrow-line { animation-delay: 0.3s; }
    .arrow-col[data-arrow="1"] .arrow-row:nth-child(5) .arrow-line { animation-delay: 0.4s; }

    /* Second arrow col: each row hidden by default, revealed individually */
    .arrow-col[data-arrow="2"] .arrow-row .arrow-line {
        opacity: 0;
        transform: scaleX(0);
        transform-origin: left;
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .arrow-col[data-arrow="2"] .arrow-row.row-visible .arrow-line {
        opacity: 1;
        transform: scaleX(1);
    }

    /* Column C: each input row hidden, revealed individually */
    .ellipse-col.col-staged .ellipse-shape {
        animation: none;
    }
    .ellipse-col.col-staged .input-wrapper {
        opacity: 0;
        transform: translateX(-8px);
        transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .ellipse-col.col-staged .input-wrapper.row-visible {
        opacity: 1;
        transform: translateX(0);
    }

    /* Feedback */
    .input-wrapper { position: relative; display: flex; flex-direction: column; align-items: center; }
    .cell-feedback {
        font-size: 0.65rem; font-weight: bold; white-space: nowrap;
        margin-top: 2px; opacity: 0; transition: opacity 0.3s;
    }
    .cell-feedback.show { opacity: 1; }
    .cell-feedback.benar { color: #2ecc71; }
    .cell-feedback.salah { color: #e74c3c; }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes arrowSlideIn {
        from { opacity: 0; transform: scaleX(0); transform-origin: left; }
        to { opacity: 1; transform: scaleX(1); transform-origin: left; }
    }
    @@keyframes ellipseEnter {
        from { opacity: 0; transform: scale(0.85); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

