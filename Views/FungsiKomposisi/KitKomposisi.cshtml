@section Scripts {
<script>
    let fFunc = null, gFunc = null;
    const valuesGof = [1, 2, 3, 4];
    const valuesFog = [4, 9, 21, 30];

    // === Parser rumus ===
    function parseRumus(str) {
        str = str.replace(/\s+/g, '');
        let m;
        // [a]x^2 [+/- b]
        m = str.match(/^([+-]?\d*)x\^2([+-]\d+)?$/);
        if (m) {
            const a = m[1] === '' || m[1] === '+' ? 1 : (m[1] === '-' ? -1 : parseFloat(m[1]));
            const b = m[2] ? parseFloat(m[2]) : 0;
            return x => a * x * x + b;
        }
        if (str === 'x^2') return x => x * x;
        // [a]x [+/- b]
        m = str.match(/^([+-]?\d*)x([+-]\d+)?$/);
        if (m) {
            const a = m[1] === '' || m[1] === '+' ? 1 : (m[1] === '-' ? -1 : parseFloat(m[1]));
            const b = m[2] ? parseFloat(m[2]) : 0;
            return x => a * x + b;
        }
        if (str === 'x') return x => x;
        m = str.match(/^([+-]?\d+(\.\d+)?)$/);
        if (m) { const c = parseFloat(m[1]); return x => c; }
        return null;
    }

    // === Validasi rumus otomatis ===
    function validateFormula() {
        const fStr = document.getElementById('inputFx').value.trim();
        const gStr = document.getElementById('inputGx').value.trim();
        const warning = document.getElementById('formulaWarning');
        const parsedF = parseRumus(fStr);
        const parsedG = parseRumus(gStr);

        if (!fStr || !gStr) {
            warning.style.display = 'none';
            fFunc = null; gFunc = null;
            return;
        }
        if (!parsedF || !parsedG) {
            warning.style.display = 'block';
            fFunc = null; gFunc = null;
            return;
        }
        warning.style.display = 'none';
        fFunc = parsedF;
        gFunc = parsedG;
        clearAllInputs();
    }

    // === Tab switch ===
    function switchTab(mode) {
        document.querySelectorAll('.kit-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.kit-panel').forEach(p => p.classList.remove('active'));
        if (mode === 'gof') {
            document.querySelectorAll('.kit-tab')[0].classList.add('active');
            document.getElementById('panelGof').classList.add('active');
        } else {
            document.querySelectorAll('.kit-tab')[1].classList.add('active');
            document.getElementById('panelFog').classList.add('active');
        }
    }

    // === Auto-validate on input ===
    function autoValidate(input) {
        if (!fFunc || !gFunc) return;
        const val = parseFloat(input.value);
        if (isNaN(val) || input.value.trim() === '') {
            input.classList.remove('correct', 'wrong');
            const fbId = input.closest('.input-wrapper')?.querySelector('.cell-feedback');
            if (fbId) { fbId.textContent = ''; fbId.classList.remove('show', 'benar', 'salah'); }
            return;
        }

        const cls = input.className;
        const row = parseInt(input.dataset.row);
        let expected;

        if (cls.includes('gof-b')) {
            expected = fFunc(valuesGof[row]);
        } else if (cls.includes('gof-c')) {
            const bInput = document.querySelector('.gof-b[data-row="' + row + '"]');
            const bVal = parseFloat(bInput.value);
            expected = !isNaN(bVal) ? gFunc(bVal) : gFunc(fFunc(valuesGof[row]));
        } else if (cls.includes('gof-d')) {
            expected = gFunc(fFunc(valuesGof[row]));
        } else if (cls.includes('fog-b')) {
            expected = gFunc(valuesFog[row]);
        } else if (cls.includes('fog-c')) {
            const bInput = document.querySelector('.fog-b[data-row="' + row + '"]');
            const bVal = parseFloat(bInput.value);
            expected = !isNaN(bVal) ? fFunc(bVal) : fFunc(gFunc(valuesFog[row]));
        } else if (cls.includes('fog-d')) {
            expected = fFunc(gFunc(valuesFog[row]));
        }

        if (expected === undefined) return;

        const rounded = Math.round(expected * 100) / 100;
        const valRounded = Math.round(val * 100) / 100;
        const isCorrect = Math.abs(valRounded - rounded) < 0.01;

        const fb = input.closest('.input-wrapper')?.querySelector('.cell-feedback');

        input.classList.remove('correct', 'wrong');
        if (isCorrect) {
            input.classList.add('correct');
            if (fb) { fb.textContent = 'Jawaban anda benar'; fb.className = 'cell-feedback show benar'; }
        } else {
            input.classList.add('wrong');
            if (fb) { fb.textContent = 'Jawaban Salah'; fb.className = 'cell-feedback show salah'; }
        }
    }

    function clearAllInputs() {
        document.querySelectorAll('.ellipse-input').forEach(inp => {
            inp.value = '';
            inp.classList.remove('correct', 'wrong');
        });
        document.querySelectorAll('.cell-feedback').forEach(fb => {
            fb.textContent = '';
            fb.classList.remove('show', 'benar', 'salah');
        });
    }

    // === Event listeners ===
    document.addEventListener('DOMContentLoaded', function() {
        // Auto-validate formula on input
        document.getElementById('inputFx').addEventListener('input', validateFormula);
        document.getElementById('inputGx').addEventListener('input', validateFormula);

        // Auto-validate answers on input
        document.querySelectorAll('.ellipse-input').forEach(input => {
            input.addEventListener('input', function() { autoValidate(this); });
        });

        // Initialize
        validateFormula();
    });
</script>
}
