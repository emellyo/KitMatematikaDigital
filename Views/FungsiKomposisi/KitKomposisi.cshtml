@section Scripts {
<script>
    let fFunc = null, gFunc = null;
    const valuesGof = [1, 2, 3, 4];
    const valuesFog = [4, 9, 21, 30];

    // === Parser rumus f(x) dan g(x) ===
    function parseCoeff(s) {
        if (s === '' || s === '+') return 1;
        if (s === '-') return -1;
        return parseFloat(s);
    }
    function parseRumus(str) {
        str = str.replace(/\s+/g, '');
        let m;
        m = str.match(/^([+-]?\d*)x\^2([+-]\d+)?$/);
        if (m) { return x => parseCoeff(m[1]) * x * x + (m[2] ? parseFloat(m[2]) : 0); }
        if (str === 'x^2') return x => x * x;
        m = str.match(/^([+-]?\d*)x([+-]\d+)?$/);
        if (m) { return x => parseCoeff(m[1]) * x + (m[2] ? parseFloat(m[2]) : 0); }
        if (str === 'x') return x => x;
        m = str.match(/^([+-]?\d+(\.\d+)?)$/);
        if (m) { const c = parseFloat(m[1]); return x => c; }
        return null;
    }

    // === Evaluator ekspresi matematika fleksibel ===
    function evalExpr(str, xVal) {
        str = str.replace(/\s+/g, '');
        let pos = 0;
        function peek() { return pos < str.length ? str[pos] : null; }
        function consume(ch) { if (str[pos] === ch) { pos++; return true; } return false; }
        function expr() {
            let r = term();
            while (true) {
                if (consume('+')) r += term();
                else if (peek() === '-' && pos > 0) { pos++; r -= term(); }
                else break;
            }
            return r;
        }
        function term() {
            let r = power();
            while (true) {
                if (consume('*')) r *= power();
                else if (peek() === '(' || peek() === 'x') r *= power();
                else break;
            }
            return r;
        }
        function power() {
            let r = unary();
            while (consume('^')) r = Math.pow(r, unary());
            return r;
        }
        function unary() {
            if (consume('-')) return -atom();
            if (consume('+')) return atom();
            return atom();
        }
        function atom() {
            if (consume('(')) { let r = expr(); consume(')'); return r; }
            if (peek() === 'x') { pos++; return xVal; }
            let s = pos;
            while (pos < str.length && (str[pos] >= '0' && str[pos] <= '9' || str[pos] === '.')) pos++;
            if (pos > s) return parseFloat(str.substring(s, pos));
            return NaN;
        }
        let r = expr();
        return (pos === str.length) ? r : NaN;
    }

    // === Validasi rumus komposisi ===
    function validateCompositionFormula(formulaStr, outerFunc, innerFunc, testValues) {
        const allTests = [...testValues, 0, -1, 5, 7];
        for (let i = 0; i < allTests.length; i++) {
            const expected = outerFunc(innerFunc(allTests[i]));
            const actual = evalExpr(formulaStr, allTests[i]);
            if (isNaN(actual)) return null;
            if (Math.abs(expected - actual) > 0.01) return false;
        }
        return true;
    }

    // === Sinkronkan input f(x) dan g(x) antar tab ===
    function syncInputs(changedInput) {
        const cls = changedInput.classList.contains('input-fx') ? '.input-fx' : '.input-gx';
        document.querySelectorAll(cls).forEach(inp => {
            if (inp !== changedInput) inp.value = changedInput.value;
        });
        validateFormula();
    }

    // === Validasi rumus f(x) dan g(x) ===
    function validateFormula() {
        const fStr = document.querySelector('.input-fx')?.value.trim() || '';
        const gStr = document.querySelector('.input-gx')?.value.trim() || '';
        const warning = document.getElementById('formulaWarning');
        const parsedF = parseRumus(fStr);
        const parsedG = parseRumus(gStr);
        if (!fStr || !gStr) { warning.style.display = 'none'; fFunc = null; gFunc = null; return; }
        if (!parsedF || !parsedG) { warning.style.display = 'block'; fFunc = null; gFunc = null; return; }
        warning.style.display = 'none';
        fFunc = parsedF;
        gFunc = parsedG;
        clearAllInputs();
    }

    // === Tab switch ===
    function switchTab(mode) {
        document.querySelectorAll('.kit-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.kit-panel').forEach(p => p.classList.remove('active'));
        if (mode === 'gof') {
            document.querySelectorAll('.kit-tab')[0].classList.add('active');
            document.getElementById('panelGof').classList.add('active');
        } else {
            document.querySelectorAll('.kit-tab')[1].classList.add('active');
            document.getElementById('panelFog').classList.add('active');
        }
    }

    // === Per-row: munculkan panah ke C hanya untuk baris yang kolom B-nya benar ===
    function checkShowArrowRow(prefix, row) {
        const arrowId = prefix === 'gof' ? 'gofArrow2' : 'fogArrow2';
        const colId = prefix === 'gof' ? 'gofColC' : 'fogColC';
        const arrowEl = document.getElementById(arrowId);
        const colEl = document.getElementById(colId);

        const bInput = document.querySelector('.' + prefix + '-b[data-row="' + row + '"]');
        const isCorrect = bInput && bInput.classList.contains('correct');

        // Arrow row (nth-child is 1-indexed, +2 because first child is the label)
        const arrowRows = arrowEl.querySelectorAll('.arrow-row');
        const colWrappers = colEl.querySelectorAll('.input-wrapper');

        if (arrowRows[row]) {
            if (isCorrect) arrowRows[row].classList.add('row-visible');
            else arrowRows[row].classList.remove('row-visible');
        }
        if (colWrappers[row]) {
            if (isCorrect) colWrappers[row].classList.add('row-visible');
            else colWrappers[row].classList.remove('row-visible');
        }
    }

    function checkAllArrowRows(prefix) {
        for (let i = 0; i < 4; i++) checkShowArrowRow(prefix, i);
    }

    // === Validasi kolom B dan C ===
    function autoValidate(input) {
        if (!fFunc || !gFunc) return;
        const val = parseFloat(input.value);
        if (isNaN(val) || input.value.trim() === '') {
            input.classList.remove('correct', 'wrong');
            const fb = input.closest('.input-wrapper')?.querySelector('.cell-feedback');
            if (fb) { fb.textContent = ''; fb.classList.remove('show', 'benar', 'salah'); }
            // Re-check arrow visibility for this row
            const r = parseInt(input.dataset.row);
            if (input.className.includes('gof-b')) checkShowArrowRow('gof', r);
            if (input.className.includes('fog-b')) checkShowArrowRow('fog', r);
            return;
        }

        const cls = input.className;
        const row = parseInt(input.dataset.row);
        let expected;

        if (cls.includes('gof-b')) expected = fFunc(valuesGof[row]);
        else if (cls.includes('gof-c')) {
            const bVal = parseFloat(document.querySelector('.gof-b[data-row="' + row + '"]').value);
            expected = !isNaN(bVal) ? gFunc(bVal) : gFunc(fFunc(valuesGof[row]));
        }
        else if (cls.includes('fog-b')) expected = gFunc(valuesFog[row]);
        else if (cls.includes('fog-c')) {
            const bVal = parseFloat(document.querySelector('.fog-b[data-row="' + row + '"]').value);
            expected = !isNaN(bVal) ? fFunc(bVal) : fFunc(gFunc(valuesFog[row]));
        }

        if (expected === undefined) return;
        const isCorrect = Math.abs(Math.round(val * 100) / 100 - Math.round(expected * 100) / 100) < 0.01;
        const fb = input.closest('.input-wrapper')?.querySelector('.cell-feedback');

        input.classList.remove('correct', 'wrong');
        if (isCorrect) {
            input.classList.add('correct');
            if (fb) { fb.textContent = 'Jawaban anda benar'; fb.className = 'cell-feedback show benar'; }
        } else {
            input.classList.add('wrong');
            if (fb) { fb.textContent = 'Jawaban anda salah'; fb.className = 'cell-feedback show salah'; }
        }

        // After validating column B, show/hide arrow for this specific row
        if (cls.includes('gof-b')) checkShowArrowRow('gof', row);
        if (cls.includes('fog-b')) checkShowArrowRow('fog', row);
    }

    // === Validasi rumus komposisi ===
    function validateCompositionInput(inputId, fbId, outerFunc, innerFunc, testValues) {
        const input = document.getElementById(inputId);
        const fb = document.getElementById(fbId);
        const str = input.value.trim();
        if (!fFunc || !gFunc || !str) {
            input.classList.remove('correct', 'wrong');
            fb.textContent = ''; fb.className = 'formula-feedback';
            return;
        }
        const result = validateCompositionFormula(str, outerFunc, innerFunc, testValues);
        input.classList.remove('correct', 'wrong');
        if (result === null) {
            input.classList.add('wrong');
            fb.textContent = 'Input rumus sesuai perintah'; fb.className = 'formula-feedback show salah';
        } else if (result === false) {
            input.classList.add('wrong');
            fb.textContent = 'Jawaban anda salah'; fb.className = 'formula-feedback show salah';
        } else {
            input.classList.add('correct');
            fb.textContent = 'Jawaban anda benar'; fb.className = 'formula-feedback show benar';
        }
    }

    function clearAllInputs() {
        document.querySelectorAll('.ellipse-input').forEach(inp => {
            inp.value = ''; inp.classList.remove('correct', 'wrong');
        });
        document.querySelectorAll('.cell-feedback').forEach(fb => {
            fb.textContent = ''; fb.classList.remove('show', 'benar', 'salah');
        });
        ['inputGofFormula', 'inputFogFormula'].forEach(id => {
            const el = document.getElementById(id);
            if (el) { el.value = ''; el.classList.remove('correct', 'wrong'); }
        });
        ['fbGofFormula', 'fbFogFormula'].forEach(id => {
            const el = document.getElementById(id);
            if (el) { el.textContent = ''; el.className = 'formula-feedback'; }
        });
        // Reset arrows & column C to hidden
        checkAllArrowRows('gof');
        checkAllArrowRows('fog');
    }

    // === Event listeners ===
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.input-fx, .input-gx').forEach(input => {
            input.addEventListener('input', function() { syncInputs(this); });
        });
        document.querySelectorAll('.ellipse-input').forEach(input => {
            input.addEventListener('input', function() { autoValidate(this); });
        });
        document.getElementById('inputGofFormula').addEventListener('input', function() {
            if (fFunc && gFunc) validateCompositionInput('inputGofFormula', 'fbGofFormula', gFunc, fFunc, valuesGof);
        });
        document.getElementById('inputFogFormula').addEventListener('input', function() {
            if (fFunc && gFunc) validateCompositionInput('inputFogFormula', 'fbFogFormula', fFunc, gFunc, valuesFog);
        });
        validateFormula();
    });
</script>
}
